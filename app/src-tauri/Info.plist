<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Senza questi, macOS 14+ NEGA silenziosamente mic/fotocamera → il mic dà silenzio e Whisper
         trascrive "[Musica]". Tauri fa il merge di questo Info.plist nel bundle .app. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Liara usa il microfono per la trascrizione vocale, elaborata solo in locale sul tuo dispositivo.</string>
    <key>NSCameraUsageDescription</key>
    <string>Liara usa la fotocamera per analizzare le immagini che scegli, elaborate solo in locale.</string>
</dict>
</plist>
